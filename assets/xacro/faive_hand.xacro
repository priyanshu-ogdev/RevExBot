            <inertial><mass value="${0.02 * mass_scale}"/><inertia ixx="${0.0001 * inertia_scale}" ixy="0" ixz="0" iyy="${0.0001 * inertia_scale}" iyz="0" izz="${0.0001 * inertia_scale}"/></inertial>
        </link>
        <joint name="${prefix}pinky_dp_joint" type="revolute">
            <origin xyz="${0.00709 * s} ${0.02745 * s * f_y} ${0.00292 * s}" rpy="0 0 0"/>
            <parent link="${prefix}pinky_mp"/>
            <child link="${prefix}pinky_dp"/>
            <axis xyz="-0.950980299137689 ${0.223061123902897 * f_y} 0.214196651829969"/>
