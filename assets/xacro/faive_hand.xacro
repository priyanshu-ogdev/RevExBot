        <link name="${prefix}pinky_dp">
            <visual><origin xyz="${-0.06245 * s + pinky_x_shift} ${-0.18421 * s * f_y} ${-0.02196 * s}" rpy="0 0 0"/><geometry><mesh filename="${mesh_dir}/${prefix}pinky_dp.stl" scale="${s} ${s} ${s}"/></geometry></visual>
