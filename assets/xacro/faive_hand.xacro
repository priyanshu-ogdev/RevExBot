        <joint name="${prefix}pinky_pp_joint" type="revolute">
            <origin xyz="${0.04565 * s} ${0.11920 * s * f_y} ${0.01504 * s}" rpy="0 0 0"/>
            <parent link="${prefix}palm"/>
            <child link="${prefix}pinky_pp"/>
            <axis xyz="-0.950980299137689 ${0.223061123902897 * f_y} 0.214196651829969"/>
            <limit lower="0" upper="0.83" effort="0.5" velocity="8"/>
            <dynamics damping="0.1" friction="0.03" armature="0.001"/>
        </joint>

        <link name="${prefix}pinky_mp">
            <visual><origin xyz="${-0.05536 * s + pinky_x_shift} ${-0.15676 * s * f_y} ${-0.01904 * s}" rpy="0 0 0"/><geometry><mesh filename="${mesh_dir}/${prefix}pinky_mp.stl" scale="${s} ${s} ${s}"/></geometry></visual>
            <collision><origin xyz="${pinky_x_shift} ${0.013 * s * f_y} 0" rpy="1.5708 0 0"/><geometry><cylinder radius="${0.01 * s}" length="${0.027 * s}"/></geometry></collision>
            <inertial><mass value="${0.02 * mass_scale}"/><inertia ixx="${0.0001 * inertia_scale}" ixy="0" ixz="0" iyy="${0.0001 * inertia_scale}" iyz="0" izz="${0.0001 * inertia_scale}"/></inertial>
        </link>
        <joint name="${prefix}pinky_mp_joint" type="revolute">
            <origin xyz="${0.00971 * s} ${0.03756 * s * f_y} ${0.00400 * s}" rpy="0 0 0"/>
            <parent link="${prefix}pinky_pp"/>
            <child link="${prefix}pinky_mp"/>
            <axis xyz="-0.950980299137689 ${0.223061123902897 * f_y} 0.214196651829969"/>
            <limit lower="0" upper="0.96" effort="0.3" velocity="8"/>
            <dynamics damping="0.1" friction="0.03" armature="0.001"/>
