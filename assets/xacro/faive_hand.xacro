            <child link="${prefix}ring_dp"/>
            <axis xyz="-0.990425994580321 ${0.104241812967506 * f_y} 0.090498583905110"/>
            <limit lower="0" upper="0.68" effort="0.2" velocity="8"/>
            <dynamics damping="0.1" friction="0.03" armature="0.001"/>
        </joint>

        <xacro:property name="pinky_x_shift" value="-0.0044225" />

        <link name="${prefix}pinky_pp">
            <visual><origin xyz="${-0.04565 * s + pinky_x_shift} ${-0.11920 * s * f_y} ${-0.01504 * s}" rpy="0 0 0"/><geometry><mesh filename="${mesh_dir}/${prefix}pinky_pp.stl" scale="${s} ${s} ${s}"/></geometry></visual>
            <collision><origin xyz="${pinky_x_shift} ${0.018 * s * f_y} 0" rpy="1.5708 0 0"/><geometry><cylinder radius="${0.01 * s}" length="${0.037 * s}"/></geometry></collision>
            <inertial><mass value="${0.02 * mass_scale}"/><inertia ixx="${0.0001 * inertia_scale}" ixy="0" ixz="0" iyy="${0.0001 * inertia_scale}" iyz="0" izz="${0.0001 * inertia_scale}"/></inertial>
