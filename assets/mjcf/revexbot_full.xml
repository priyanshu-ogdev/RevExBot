<mujoco model="RevEx_Full_Assembly">
  <compiler angle="radian" meshdir="../assets/meshes" autolimits="true"/>

  <option timestep="0.005" iterations="4" ls_iterations="8" integrator="implicitfast" solver="Newton">
    <flag sensornoise="disable" contact="enable"/>
  </option>

  <default>
    <!-- Visual Geoms -->
    <default class="visual">
      <geom contype="0" conaffinity="0" group="2" rgba="0.7 0.7 0.7 1"/>
    </default>

    <!-- Collision Geoms -->
    <default class="collision">
      <geom group="3" rgba="0.5 0.5 0.5 0.3" type="capsule" contype="1" conaffinity="1"/>
    </default>

    <!-- Motor Joints (Legs, Arms, Waist) -->
    <default class="motor">
      <joint damping="0" armature="0.01" frictionloss="0"/>
      <position kp="150" kv="5" forcerange="-100 100" ctrlrange="-3.14 3.14"/>
    </default>

    <!-- Passive Upper Body (Neck) -->
    <default class="passive_upper">
      <joint damping="15.0" stiffness="80.0" springref="0" armature="0.05"/>
    </default>

    <!-- Hand Joints (Faive Style) -->
    <default class="hand_motor">
      <joint damping="0.05" armature="0.001" frictionloss="0.001" margin="0.01"/>
      <position kp="2.0" kv="0.1" forcerange="-1 1"/>
    </default>
  </default>

  <asset>
    <material name="visual_grey" rgba="0.7 0.7 0.7 1.0" />
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"/>
    <material name="groundplane" texture="texplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!-- Humanoid Meshes -->
    <mesh name="pelvis" file="IMU_ORIGIN.STL" />
    <mesh name="left_hip_pitch" file="LEFT_HIP_PITCH.STL" />
    <mesh name="left_hip_roll" file="LEFT_HIP_ROLL.STL" />
    <mesh name="left_hip_yaw" file="LEFT_HIP_YAW.STL" />
    <mesh name="left_knee" file="LEFT_KNEE.STL" />
    <mesh name="left_ankle_a" file="LEFT_ANKLE_A.STL" />
    <mesh name="left_ankle_b" file="LEFT_ANKLE_B.STL" />
    <mesh name="left_toe" file="LEFT_TOE.STL" />
    <mesh name="right_hip_pitch" file="RIGHT_HIP_PITCH.STL" />
    <mesh name="right_hip_roll" file="RIGHT_HIP_ROLL.STL" />
    <mesh name="right_hip_yaw" file="RIGHT_HIP_YAW.STL" />
    <mesh name="right_knee" file="RIGHT_KNEE.STL" />
