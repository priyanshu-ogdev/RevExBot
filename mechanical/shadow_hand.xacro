        </link>

        <link name="${prefix}lfproximal">
            <inertial><mass value="0.030" /><origin xyz="0 0 0.0225" /><inertia ixx="0.0000098" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.0000018" /></inertial>
            <visual><origin rpy="0 0 0" xyz="0 0 0" /><geometry><mesh filename="${mesh_dir}/${prefix}f_proximal_E3M5.stl" /></geometry><material name="Grey" /></visual>
            <collision><origin rpy="0 0 0" xyz="0 0 0.025" /><geometry><cylinder length="0.040" radius="0.007" /></geometry></collision>
        </link>
        <joint name="${prefix}LFJ3" type="revolute">
            <parent link="${prefix}lfknuckle" /><child link="${prefix}lfproximal" />
            <origin rpy="0 0 0" xyz="0 0 0" />
            <axis xyz="1 0 0" />
            <limit effort="2" lower="-0.2617993877991494" upper="1.5707963267948966" velocity="2.0" /><dynamics damping="0.1" />
        </joint>

        <link name="${prefix}lfmiddle">
            <inertial><origin rpy="0 0 0" xyz="0 0 0.0125" /><mass value="0.017" /><inertia ixx="0.0000026" ixy="0.0" ixz="0.0" iyy="0.0000027" iyz="0.0" izz="0.00000087" /></inertial>
            <visual><origin rpy="0 0 0" xyz="0 0 0" /><geometry><mesh filename="${mesh_dir}/${prefix}f_middle_E3M5.stl" /></geometry><material name="Grey" /></visual>
            <collision><origin rpy="0 0 0" xyz="0 0 0.0125" /><geometry><cylinder length="0.025" radius="0.007" /></geometry></collision>
            <collision><origin rpy="0 0 0" xyz="0 0 0.0" /><geometry><sphere radius="0.007" /></geometry></collision>
            <collision><origin rpy="0 0 0" xyz="0 0 0.025" /><geometry><sphere radius="0.007" /></geometry></collision>
        </link>
        <joint name="${prefix}LFJ2" type="revolute">
            <parent link="${prefix}lfproximal" /><child link="${prefix}lfmiddle" />
            <origin rpy="0 0 0" xyz="0 0 0.045" />
            <axis xyz="1 0 0" />
            <limit effort="2" lower="0" upper="1.5707963267948966" velocity="2.0" /><dynamics damping="0.1" />
        </joint>

        <link name="${prefix}lfdistal">
