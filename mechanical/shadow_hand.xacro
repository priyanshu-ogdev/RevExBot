            <visual><origin rpy="0 0 ${1.5707963267948966 * f_x}" xyz="0 0 0" /><geometry><mesh filename="${mesh_dir}/${prefix}th_proximal_E3M5.stl" /></geometry><material name="shadow_thproximal_material"><color rgba="0.2 0.2 0.2 1.0" /></material></visual>
            <collision><origin rpy="0 0 0" xyz="0 0 0.020" /><geometry><cylinder length="0.018" radius="0.012" /></geometry></collision>
        </link>
        
