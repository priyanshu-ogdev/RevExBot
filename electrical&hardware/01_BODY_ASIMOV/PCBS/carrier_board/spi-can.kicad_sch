	(text "C_L = (C**2 / 2C) + C_S\n\nC_L = load capacitance\nC_S = stray capacitance\nC = decoupling capacitance\n\nAssume C_L = 15p, C_S = 5p,\n2C * 10p = C**2\n20p * C = C**2\nC = 20p\n\nChoosing 20p, closest value available\n"
		(exclude_from_sim no)
		(at 32.512 145.034 0)
